# 复制为 .env 并填入真实值，不要提交 .env 到版本库

# ========== Key / 地址 / 模型 分别是什么 ==========
# API Key：你在「哪个网站」开通，key 就属于那个平台。
# OPENAI_API_BASE：OpenAI 兼容接口的根地址（须含 https://，常以 /v1 结尾）。
# LLM_MODEL：该平台文档里的 model 名称。

# ---------- 方案 A：OpenAI 官方（国内常需代理或中转）----------
# OPENAI_API_KEY=sk-xxx
# OPENAI_API_BASE=
# LLM_MODEL=gpt-4o-mini

# ---------- 方案 B：阿里云百炼（DashScope，OpenAI 兼容）----------
# OPENAI_API_KEY=sk-在百炼控制台复制的 Key
# OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# 新加坡地域可改为：https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# 模型列表：https://help.aliyun.com/zh/model-studio/getting-started/models

OPENAI_API_KEY=
OPENAI_API_BASE=
LLM_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=120

# 若使用其他模型（Anthropic / 国产等），可在此增加
# ANTHROPIC_API_KEY=
# DASHSCOPE_API_KEY=   # 通义千问等
